class ListNode:
    def __init__(self, val=0, next=None):
        self.val = val
        self.next = next
def has_cycle(head: ListNode) -> bool:
    slow = head
    fast = head
    while fast and fast.next:
        slow = slow.next
        fast = fast.next.next
        if slow == fast:
            return True
    return False
def build_linked_list(values):
    if not values:
        return None
    head = ListNode(values[0])
    curr = head
    for v in values[1:]:
        curr.next = ListNode(v)
        curr = curr.next
    return head
head1 = build_linked_list([1, 2, 3, 4])
print(has_cycle(head1))
head2 = build_linked_list([1, 2, 3, 4])
curr = head2
while curr.next:
    curr = curr.next
curr.next = head2.next
print(has_cycle(head2))
