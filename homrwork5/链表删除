class Node:
    def __init__(self, data: str | int | float):
        self.data: str | int | float = data
        self.next_node: Node | None = None
    def __repr__(self) -> str:
        return f"Node({self.data!r})"
class LinkedList:
    def __init__(self):
        self.first_node: Node | None = None
    def __repr__(self) -> str:
        if not self.first_node:
            return "LinkedList([])"
        nodes: list[str] = []
        current: Node | None = self.first_node
        while current:
            nodes.append(str(current.data))
            current = current.next_node
        return f"LinkedList({', '.join(nodes)})"
    def delete_at_index(self, index: int) -> None:
        if self.first_node is None:
            raise IndexError("空链表，无法删除")
        if index == 0:
            self.first_node = self.first_node.next_node
            return
        prev = self.first_node
        count = 0
        while prev is not None and count < index - 1:
            prev = prev.next_node
            count += 1
        if prev is None or prev.next_node is None:
            raise IndexError("索引超出范围")
        to_delete = prev.next_node
        prev.next_node = to_delete.next_node
ll = LinkedList()
ll.first_node = Node(1)
ll.first_node.next_node = Node(2)
ll.first_node.next_node.next_node = Node(3)
ll.first_node.next_node.next_node.next_node = Node(4)
print(ll)
ll.delete_at_index(2)
